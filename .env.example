# Gmail SMTP for contact form notifications (required on production Pi)
SMTP_USER=bhargava.gumpula@gmail.com
SMTP_PASS=your-gmail-app-password

# Optional SMTP overrides
# CONTACT_NOTIFY_EMAIL=bhargava.gumpula@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Testimonial moderation (required for /admin/testimonials)
TESTIMONIALS_ADMIN_PASSWORD=choose-a-long-unique-password
# Generate with: openssl rand -base64 32
TESTIMONIALS_ADMIN_SESSION_SECRET=generate-a-random-secret

# Stripe (test mode first — see PHASE_1_IMPLEMENTATION_PLAN.md)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public site URL for Stripe redirect URLs (production: https://www.bhargava-gumpula.com)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe Price IDs (test mode — from Product catalog in Stripe dashboard)
STRIPE_PRICE_RUBIKS_1_ON_1=price_...
STRIPE_PRICE_RUBIKS_GROUP=price_...
STRIPE_PRICE_PYTHON_1_ON_1=price_...
STRIPE_PRICE_PYTHON_GROUP=price_...

# Google Calendar (private teaching calendar — see PHASE_1_IMPLEMENTATION_PLAN.md walkthrough)
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=...@....iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Pi only — clear stale pm2 proxy so Google Calendar API is reachable
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=googleapis.com,www.googleapis.com,127.0.0.1,localhost
